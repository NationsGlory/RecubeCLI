{
  "name": "@nationsglory/cli",
  "version": "0.7.0",
  "description": "Recube CLI développeur — publie des builds de jeu avec auth OAuth",
  "type": "module",
  "bin": {
    "recube": "./dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "build:binary": "node scripts/build-binary.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Recube",
  "homepage": "https://recube.gg",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NationsGlory/RecubeCLI.git"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "recube",
    "cli",
    "launcher",
    "publish",
    "oauth"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  }
}
